rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow the server-side centralized state synchronization document to be read and written
    match /system/databaseState {
      allow read, write: if true;
    }

    // Allow authenticated users to read and write their own backup documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
